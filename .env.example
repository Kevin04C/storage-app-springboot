# StoneStorage Environment Variables
# Copy this file to .env and modify the values for your environment

# Database Configuration
POSTGRES_PASSWORD=your-secure-database-password
SPRING_R2DBC_URL=r2dbc:postgresql://postgres:5432/storage_app
SPRING_R2DBC_USERNAME=stonestorage
SPRING_R2DBC_PASSWORD=your-secure-database-password

# Application Configuration
ADMIN_PASSWORD=your-secure-admin-password
JAVA_OPTS=-Xmx512m -Xms256m

# Storage Configuration
STORAGE_TYPE=local
STORAGE_BASE_PATH=/data/stonestorage

# Security Configuration
# Generate random API keys or use your own
# You can generate a secure key with: openssl rand -base64 32

# Optional: External Services Configuration
# AWS_S3_ACCESS_KEY=your-s3-access-key
# AWS_S3_SECRET_KEY=your-s3-secret-key
# AWS_S3_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# Optional: Monitoring and Logging
# LOG_LEVEL=INFO
# SENTRY_DSN=your-sentry-dsn

# Optional: Performance Tuning
# SPRING_R2DBC_POOL_INITIAL_SIZE=5
# SPRING_R2DBC_POOL_MAX_SIZE=20
# SPRING_WEBFLUX_MULTIPART_MAX_IN_MEMORY_SIZE=10MB
# SPRING_WEBFLUX_MULTIPART_MAX_DISK_USAGE_PER_REQUEST=100MB
